# Public configuration — these values are baked into the build, NOT secrets.

# WhatsApp number in E.164 format WITHOUT the leading "+"
# Used in https://wa.me/<value>?text=...
PUBLIC_RESTAURANT_WHATSAPP=491742116095

# Site URL with full path. The path component (if any) is auto-derived as
# Astro's `base` config — for project pages on GitHub set it to:
#   https://<user>.github.io/<repo>
# For a custom domain, set it to:
#   https://pimp-my-kebap.de
PUBLIC_SITE_URL=https://beko2210.github.io/pimp-my-kebap
