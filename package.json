{
  "name": "pimp-my-kebap",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Pimp My Kebap — Bestell-Website (statisch, WhatsApp-Bestellung, DSGVO-konform).",
  "scripts": {
    "preflight": "node scripts/preflight.mjs",
    "build:images": "node scripts/build-images.mjs",
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "npm run preflight && npm run build:images",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint . --ext .js,.mjs,.ts,.astro",
    "format": "prettier --write .",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "audit": "npm audit --omit=dev --audit-level=high",
    "postbuild": "node scripts/version-stamp.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.4.4",
    "lucide": "^1.11.0",
    "nanostores": "^1.3.0",
    "tailwindcss": "^4.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "@vitest/coverage-v8": "^4.1.8",
    "astro-eslint-parser": "^1.1.0",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^17.5.0",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.33.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.11"
  },
  "overrides": {
    "vite": "7.3.2"
  }
}
