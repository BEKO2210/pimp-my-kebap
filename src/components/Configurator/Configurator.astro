---
// Powered by skill: frontend-design, accessibility
import { BREADS } from '../../data/breads';
import { BASES, MEATS } from '../../data/configurator';
import { SAUCES, FREE_SAUCE_COUNT } from '../../data/sauces';
import { TOPPINGS } from '../../data/ingredients';
import { formatEUR } from '../../lib/format';
import Icon from '../Icon.astro';
---

<section
  id="konfigurator"
  class="px-4 sm:px-6 lg:px-8 py-12 lg:py-16"
  aria-labelledby="cfg-heading"
>
  <div class="mx-auto max-w-5xl">
    <header class="mb-8 flex items-end justify-between gap-4 flex-wrap">
      <div>
        <p class="eyebrow">Schritt für Schritt zu deinem Kebap</p>
        <h1 id="cfg-heading" class="display text-3xl sm:text-4xl lg:text-5xl text-brand-cream mt-2">
          Pimp my <span class="text-brand-gold italic">Kebap</span>
        </h1>
        <p class="text-brand-cream/70 mt-2 max-w-2xl">
          Wähle Basis, Spieß, Brot, Soßen und Toppings — die Live-Summe rechts unten aktualisiert sich bei jeder Änderung.
        </p>
      </div>
      <button
        type="button"
        data-surprise-me
        class="btn-secondary text-sm inline-flex items-center gap-2"
        aria-label="Zufalls-Kebap konfigurieren lassen"
      >
        <Icon name="dice" size={16} />
        <span>Surprise Me</span>
      </button>
    </header>

    <div data-cfg-root class="space-y-10" aria-live="polite">
      <!-- Step 1 — Basis -->
      <fieldset data-cfg-step="base" class="scroll-mt-20">
        <legend class="display text-2xl text-brand-cream mb-4 flex flex-wrap items-baseline gap-x-3 gap-y-1">
          <span>
            <span class="text-brand-gold mr-2 num">1.</span>Wähle deine Basis
          </span>
          <span
            data-cfg-step-hint
            hidden
            class="text-sm font-normal text-brand-gold/90 inline-flex items-center gap-1.5 cfg-pulse"
          >
            <span aria-hidden="true">←</span>
            <span>hier starten</span>
          </span>
        </legend>
        <p class="text-sm text-brand-cream/70 mb-4">
          Immer enthalten: 100 g vom Spieß deiner Wahl, Salat (Kraut, Zwiebel, Tomaten), 2 Soßen.
        </p>
        <div class="grid sm:grid-cols-3 gap-3">
          {BASES.map((b) => (
            <button
              type="button"
              class="card card-selectable p-4 text-left flex flex-col gap-2 min-h-[10rem]"
              data-cfg-base={b.id}
              aria-pressed="false"
            >
              <span class="display text-lg text-brand-cream">{b.name}</span>
              <span class="text-xs text-brand-cream/60">{b.description}</span>
              <span class="mt-auto text-brand-gold font-semibold num">{formatEUR(b.basePriceEur)}</span>
            </button>
          ))}
        </div>
      </fieldset>

      <!-- Step 1.5 — Spieß -->
      <fieldset data-cfg-step="meat" class="scroll-mt-20">
        <legend class="display text-2xl text-brand-cream mb-4">
          <span class="text-brand-gold mr-2 num">1.5</span>Welcher Spieß?
        </legend>
        <div role="radiogroup" aria-label="Drehspieß-Sorte" class="grid sm:grid-cols-3 gap-2">
          {MEATS.map((m, i) => (
            <button
              type="button"
              role="radio"
              aria-checked={i === 0 ? 'true' : 'false'}
              data-active={i === 0 ? 'true' : 'false'}
              class="btn-secondary !py-3 flex-col !items-start text-left"
              data-cfg-meat={m.id}
            >
              <span class="display text-base text-brand-cream">{m.name}</span>
              <span class="text-xs text-brand-cream/60 num">
                {m.upchargeEur > 0 ? `+${formatEUR(m.upchargeEur)} auf den Grundpreis` : 'kein Aufpreis'}
              </span>
            </button>
          ))}
        </div>
      </fieldset>

      <!-- Step 2 — Brot (only Kebap Basic) -->
      <fieldset data-cfg-step="bread" class="scroll-mt-20" hidden>
        <legend class="display text-2xl text-brand-cream mb-4 flex flex-wrap items-baseline gap-x-3 gap-y-1">
          <span>
            <span class="text-brand-gold mr-2 num">2.</span>Wähle dein Brot
          </span>
          <span
            data-cfg-step-hint
            hidden
            class="text-sm font-normal text-brand-gold/90 inline-flex items-center gap-1.5 cfg-pulse"
          >
            <span aria-hidden="true">←</span>
            <span>hier weitermachen</span>
          </span>
        </legend>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          {BREADS.map((b) => (
            <button
              type="button"
              class="card card-selectable p-4 text-left flex flex-col gap-2 min-h-[8rem]"
              data-cfg-bread={b.id}
              aria-pressed="false"
            >
              <span class="display text-lg text-brand-cream flex items-center gap-2">
                {b.name}
                {b.isNew && <span class="badge badge-new">NEU</span>}
              </span>
              <span class="text-xs text-brand-cream/60">{b.description}</span>
            </button>
          ))}
        </div>
      </fieldset>

      <!-- Step 3 — Soßen (multi) -->
      <fieldset data-cfg-step="sauces" class="scroll-mt-20" data-cfg-pimp-section>
        <legend class="display text-2xl text-brand-cream mb-4">
          <span class="text-brand-gold mr-2 num">3.</span>Wähle deine Soßen
        </legend>
        <p class="text-sm text-brand-cream/70 mb-4">
          {FREE_SAUCE_COUNT} Soßen sind in der Basis dabei — jede weitere kostet +0,50 €.
        </p>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
          {SAUCES.map((s) => (
            <label class="card card-selectable p-3 flex items-center gap-3 cursor-pointer" data-cfg-sauce-card={s.id}>
              <input
                type="checkbox"
                class="sr-only"
                data-cfg-sauce={s.id}
                aria-label={s.name}
              />
              <span class="text-brand-cream text-sm flex items-center gap-1">
                {s.name}
                {s.spicy && <Icon name="flame" size={12} class="text-brand-red-fire" ariaLabel="scharf" />}
              </span>
            </label>
          ))}
        </div>
      </fieldset>

      <!-- Step 4 — Toppings (multi) -->
      <fieldset data-cfg-step="toppings" class="scroll-mt-20" data-cfg-pimp-section>
        <legend class="display text-2xl text-brand-cream mb-4">
          <span class="text-brand-gold mr-2 num">4.</span>Wähle deine Toppings
          <span class="block sm:inline text-sm font-normal text-brand-cream/55">je +0,50 € · grün markierte sind kostenlos in Basis dabei</span>
        </legend>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-2">
          {TOPPINGS.map((t) => (
            <label
              class={`card card-selectable p-2 flex items-center justify-center gap-1 text-center cursor-pointer min-h-[3rem] ${t.baseIncluded ? 'cfg-topping-base-included' : ''}`}
              data-cfg-topping-card={t.id}
              data-active={t.baseIncluded ? 'true' : 'false'}
            >
              <input
                type="checkbox"
                class="sr-only"
                data-cfg-topping={t.id}
                aria-label={t.name}
                checked={t.baseIncluded}
              />
              <span class="text-brand-cream text-xs inline-flex items-center justify-center gap-1 flex-wrap">
                <span>{t.name}</span>
                {t.spicy && <Icon name="flame" size={10} class="text-brand-red-fire" ariaLabel="scharf" />}
                {t.baseIncluded && <span class="text-brand-green-leaf block text-[10px] basis-full font-semibold">in Basis · kostenlos</span>}
              </span>
            </label>
          ))}
        </div>
      </fieldset>

      <!-- Step 5 — Extras -->
      <fieldset data-cfg-step="extras" class="scroll-mt-20" data-cfg-pimp-section>
        <legend class="display text-2xl text-brand-cream mb-4">
          <span class="text-brand-gold mr-2 num">5.</span>Extras (optional)
        </legend>
        <div class="space-y-2 max-w-xl">
          <label class="card flex items-center justify-between gap-4 p-3 cursor-pointer" data-cfg-extra="schmelzkaese">
            <span class="text-brand-cream text-sm">Schmelzkäse</span>
            <span class="flex items-center gap-3">
              <span class="text-brand-gold text-sm num">+1,00 €</span>
              <input type="checkbox" data-cfg-flag="schmelzkaese" />
            </span>
          </label>
          <div class="card p-3 flex items-center justify-between gap-3">
            <span class="text-brand-cream text-sm">Mehr Fleisch (50 g)</span>
            <div class="flex items-center gap-3">
              <span class="text-brand-gold text-sm num">+1,50 €</span>
              <div class="flex items-center gap-1" role="group" aria-label="Mehr Fleisch Stepper">
                <button type="button" class="btn-secondary !px-3 !py-1 text-base" data-cfg-extra-meat="dec" aria-label="Weniger">−</button>
                <output data-cfg-extra-meat-value class="text-brand-cream w-6 text-center num">0</output>
                <button type="button" class="btn-secondary !px-3 !py-1 text-base" data-cfg-extra-meat="inc" aria-label="Mehr">+</button>
              </div>
            </div>
          </div>
          <p class="text-xs text-brand-cream/60 px-1">
            Steak: +1,00 € auf den Grundpreis (oben in Schritt 1.5 wählen).
            Extra Fleisch (50 g) kostet bei jeder Spieß-Sorte 1,50 €.
          </p>
        </div>
      </fieldset>

      <!-- Box hint — replaces Steps 3/4/5 when Kebap Box is selected -->
      <aside
        data-cfg-box-hint
        hidden
        class="rounded-xl border border-brand-gold/30 bg-brand-charcoal/60 p-5"
        role="note"
      >
        <p class="display text-xl text-brand-cream mb-2">Kebap Box — fertig komponiert</p>
        <p class="text-sm text-brand-cream/75">
          Die Box kommt mit Salat (Kraut, Zwiebel, Tomaten) und 2 Soßen deiner Wahl —
          keine zusätzlichen Toppings, kein Schmelzkäse, kein Extra-Fleisch.
          Spieß oben wählen und ab in den Warenkorb.
        </p>
      </aside>

      <!-- Sticky live summary -->
      <div
        class="cfg-sticky-footer sticky bottom-4 z-10 mt-10 rounded-xl border border-brand-gold/40 bg-brand-charcoal/95 backdrop-blur p-4 shadow-2xl flex items-center justify-between gap-4"
        data-cfg-summary
        role="status"
        aria-live="polite"
      >
        <div>
          <p class="text-xs text-brand-cream/60 uppercase tracking-wider" data-cfg-total-label>Aktueller Preis</p>
          <p class="display text-2xl text-brand-gold" data-cfg-total>Wähle deine Basis</p>
        </div>
        <button
          type="button"
          class="btn-primary"
          data-cfg-add
          disabled
        >
          In den Warenkorb →
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  import './configurator.client.ts';
</script>
