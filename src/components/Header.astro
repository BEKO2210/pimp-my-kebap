---
// Powered by skill: frontend-design, accessibility
// Mobile-first: ein einziger Row mit Logo, Status-Dot, Anruf-Icon. Volle Texte
// und CTAs erst ab `sm` (≥640 px).
import { BRAND } from '../data/brand';
import { getCurrentOpeningStatus } from '../lib/time';
import { withBase } from '../lib/url';
import Icon from './Icon.astro';

const status = getCurrentOpeningStatus();

let dotColor = 'bg-brand-red-fire';
let shortLabel = 'Geschlossen';
let fullLabel = 'Geschlossen';
let toneClass = 'text-brand-red-fire';

if (status.isOpen && status.reason === 'regular') {
  dotColor = 'bg-brand-green-leaf';
  toneClass = 'text-brand-green-leaf';
  shortLabel = `bis ${status.todayClose}`;
  fullLabel = `Jetzt geöffnet — bis ${status.todayClose} Uhr`;
} else if (status.isOpen && status.reason === 'holiday') {
  dotColor = 'bg-brand-gold';
  toneClass = 'text-brand-gold';
  shortLabel = `bis ${status.todayClose}`;
  fullLabel = `Heute Feiertag — bis ${status.todayClose} Uhr`;
} else if (status.reason === 'closed_sunday') {
  shortLabel = status.nextOpenShortLabel ?? 'Mo wieder';
  fullLabel = `Heute geschlossen (So) — ${status.nextOpenLabel ?? ''}`;
} else if (status.reason === 'before_opening') {
  shortLabel = status.nextOpenShortLabel ?? `ab ${status.todayOpen}`;
  fullLabel = `Geschlossen — ${status.nextOpenLabel ?? ''}`;
} else if (status.reason === 'after_closing') {
  shortLabel = status.nextOpenShortLabel ?? 'morgen wieder';
  fullLabel = `Geschlossen — ${status.nextOpenLabel ?? ''}`;
}
---

<header class="sticky top-0 z-30 border-b border-brand-gold/20 bg-brand-black/90 backdrop-blur">
  <div class="mx-auto max-w-6xl px-3 sm:px-6 lg:px-8 h-14 sm:h-16 flex items-center gap-3">

    <!-- Logo (always visible). Wordmark only ≥sm to keep mobile tight. -->
    <a
      href={withBase('/')}
      class="flex items-center gap-2 sm:gap-3 shrink-0"
      aria-label={`${BRAND.marketingName} Startseite`}
    >
      <picture>
        <source srcset={withBase('/brand/logo.avif')} type="image/avif" />
        <source srcset={withBase('/brand/logo.webp')} type="image/webp" />
        <img
          src={withBase('/brand/logo.png')}
          alt=""
          width="40" height="40"
          class="h-9 w-9 sm:h-11 sm:w-11 object-contain"
          decoding="async"
          fetchpriority="high"
        />
      </picture>
      <span class="display text-brand-cream text-lg leading-none whitespace-nowrap hidden sm:inline">
        Pimp My <span class="text-brand-gold">Kebap</span>
      </span>
    </a>

    <!-- Compact status: dot + 1-2 words on mobile, full label ≥sm -->
    <span
      class={`flex items-center gap-1.5 text-xs whitespace-nowrap ${toneClass}`}
      data-opening-pill
      role="status"
      aria-label={fullLabel}
    >
      <span class={`w-2 h-2 rounded-full ${dotColor} animate-pulse`} aria-hidden="true"></span>
      <span class="sm:hidden font-semibold">{shortLabel}</span>
      <span class="hidden sm:inline">{fullLabel}</span>
    </span>

    <!-- Desktop nav (hidden on mobile) -->
    <nav class="hidden md:flex items-center gap-1 text-sm" aria-label="Hauptnavigation">
      <a href={withBase('/konfigurator')} class="px-3 py-2 rounded-md text-brand-cream/85 hover:text-brand-gold hover:bg-brand-charcoal/60 transition-colors">Kebap</a>
      <a href={withBase('/pimp-my-pizza')} class="px-3 py-2 rounded-md text-brand-cream/85 hover:text-brand-gold hover:bg-brand-charcoal/60 transition-colors">Pizza</a>
      <a href={withBase('/speisekarte')} class="px-3 py-2 rounded-md text-brand-cream/85 hover:text-brand-gold hover:bg-brand-charcoal/60 transition-colors">Speisekarte</a>
    </nav>

    <!-- Spacer -->
    <span class="flex-1"></span>

    <!-- Phone icon-only on mobile, full button ≥sm -->
    <a
      href={`tel:${BRAND.contact.phoneE164}`}
      class="text-brand-cream/85 hover:text-brand-gold transition-colors p-2 -mr-1 sm:hidden"
      aria-label={`Anrufen ${BRAND.contact.phoneDisplay}`}
    >
      <Icon name="phone" size={22} />
    </a>

    <!-- Mobile burger menu (hidden ≥md, since nav is shown directly) -->
    <button
      type="button"
      data-mobile-nav-toggle
      class="relative text-brand-cream/85 hover:text-brand-gold transition-colors p-2 md:hidden"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="mobile-nav-panel"
    >
      <span class="block" data-icon-menu>
        <Icon name="menu" size={22} />
      </span>
      <span class="hidden" data-icon-close>
        <Icon name="close" size={22} />
      </span>
    </button>

    <a
      href={`tel:${BRAND.contact.phoneE164}`}
      class="btn-secondary text-xs !py-2 hidden sm:inline-flex md:hidden items-center gap-1.5"
      aria-label={`Anrufen ${BRAND.contact.phoneDisplay}`}
    >
      <Icon name="phone" size={14} />
      <span>Anrufen</span>
    </a>
  </div>

  <!-- Mobile nav panel — opened via burger; collapses by default -->
  <nav
    id="mobile-nav-panel"
    data-mobile-nav-panel
    hidden
    class="md:hidden border-t border-brand-gold/20 bg-brand-black/95 backdrop-blur"
    aria-label="Hauptnavigation (Mobile)"
  >
    <ul class="px-4 py-3 space-y-1">
      <li>
        <a href={withBase('/konfigurator')} class="flex items-center gap-3 px-3 py-3 rounded-md text-brand-cream hover:bg-brand-charcoal/70 hover:text-brand-gold transition-colors">
          <Icon name="kebap" size={20} class="text-brand-gold shrink-0" />
          <span>Pimp my Kebap</span>
        </a>
      </li>
      <li>
        <a href={withBase('/pimp-my-pizza')} class="flex items-center gap-3 px-3 py-3 rounded-md text-brand-cream hover:bg-brand-charcoal/70 hover:text-brand-gold transition-colors">
          <Icon name="pizza" size={20} class="text-brand-gold shrink-0" />
          <span>Pimp my Pizza</span>
        </a>
      </li>
      <li>
        <a href={withBase('/speisekarte')} class="flex items-center gap-3 px-3 py-3 rounded-md text-brand-cream hover:bg-brand-charcoal/70 hover:text-brand-gold transition-colors">
          <Icon name="menu-list" size={20} class="text-brand-gold shrink-0" />
          <span>Speisekarte</span>
        </a>
      </li>
      <li class="border-t border-brand-gold/15 mt-2 pt-2">
        <a href={`tel:${BRAND.contact.phoneE164}`} class="flex items-center gap-3 px-3 py-3 rounded-md text-brand-cream hover:bg-brand-charcoal/70 hover:text-brand-gold transition-colors">
          <Icon name="phone" size={20} class="text-brand-gold shrink-0" />
          <span>Anrufen · {BRAND.contact.phoneDisplay}</span>
        </a>
      </li>
    </ul>
  </nav>
</header>

<script>
  (function () {
    const toggle = document.querySelector<HTMLButtonElement>('[data-mobile-nav-toggle]');
    const panel = document.querySelector<HTMLElement>('[data-mobile-nav-panel]');
    if (!toggle || !panel) return;

    const iconMenu = toggle.querySelector<HTMLElement>('[data-icon-menu]');
    const iconClose = toggle.querySelector<HTMLElement>('[data-icon-close]');

    const setOpen = (open: boolean) => {
      if (open) {
        panel.removeAttribute('hidden');
        toggle.setAttribute('aria-expanded', 'true');
        toggle.setAttribute('aria-label', 'Menü schließen');
        document.body.classList.add('mobile-nav-open');
        iconMenu?.classList.add('hidden');
        iconMenu?.classList.remove('block');
        iconClose?.classList.remove('hidden');
        iconClose?.classList.add('block');
      } else {
        panel.setAttribute('hidden', '');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Menü öffnen');
        document.body.classList.remove('mobile-nav-open');
        iconMenu?.classList.remove('hidden');
        iconMenu?.classList.add('block');
        iconClose?.classList.add('hidden');
        iconClose?.classList.remove('block');
      }
    };

    const isOpen = () => !panel.hasAttribute('hidden');

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      setOpen(!isOpen());
    });

    // ESC closes
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen()) {
        setOpen(false);
        toggle.focus();
      }
    });

    // Outside click closes
    document.addEventListener('click', (e) => {
      if (!isOpen()) return;
      const target = e.target as Node;
      if (panel.contains(target) || toggle.contains(target)) return;
      setOpen(false);
    });

    // Close panel when a link inside is clicked
    panel.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => setOpen(false)),
    );

    // Close on resize to ≥md (panel only relevant <md)
    const mq = window.matchMedia('(min-width: 768px)');
    mq.addEventListener('change', (ev) => {
      if (ev.matches && isOpen()) setOpen(false);
    });
  })();
</script>
