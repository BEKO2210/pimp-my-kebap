---
// Powered by skill: frontend-design, accessibility
// Mobile-first: ein einziger Row mit Logo, Status-Dot, Anruf-Icon. Volle Texte
// und CTAs erst ab `sm` (≥640 px).
import { BRAND } from '../data/brand';
import { getCurrentOpeningStatus } from '../lib/time';
import { withBase } from '../lib/url';

const status = getCurrentOpeningStatus();

let dotColor = 'bg-brand-red-fire';
let shortLabel = 'Geschlossen';
let fullLabel = 'Geschlossen';
let toneClass = 'text-brand-red-fire';

if (status.isOpen && status.reason === 'regular') {
  dotColor = 'bg-brand-green-leaf';
  toneClass = 'text-brand-green-leaf';
  shortLabel = `bis ${status.todayClose}`;
  fullLabel = `Jetzt geöffnet — bis ${status.todayClose} Uhr`;
} else if (status.isOpen && status.reason === 'holiday') {
  dotColor = 'bg-brand-gold';
  toneClass = 'text-brand-gold';
  shortLabel = `bis ${status.todayClose}`;
  fullLabel = `Heute Feiertag — bis ${status.todayClose} Uhr`;
} else if (status.reason === 'closed_sunday') {
  shortLabel = 'Mo wieder offen';
  fullLabel = `Heute geschlossen (So) — ${status.nextOpenLabel ?? ''}`;
} else if (status.reason === 'before_opening') {
  shortLabel = `ab ${status.todayOpen}`;
  fullLabel = `Geschlossen — ${status.nextOpenLabel ?? ''}`;
} else if (status.reason === 'after_closing') {
  shortLabel = 'morgen wieder';
  fullLabel = `Geschlossen — ${status.nextOpenLabel ?? ''}`;
}
---

<header class="sticky top-0 z-30 border-b border-brand-gold/20 bg-brand-black/90 backdrop-blur">
  <div class="mx-auto max-w-6xl px-3 sm:px-6 lg:px-8 h-14 sm:h-16 flex items-center gap-3">

    <!-- Logo (always visible). Wordmark only ≥sm to keep mobile tight. -->
    <a
      href={withBase('/')}
      class="flex items-center gap-2 sm:gap-3 shrink-0"
      aria-label={`${BRAND.marketingName} Startseite`}
    >
      <picture>
        <source srcset={withBase('/brand/logo.avif')} type="image/avif" />
        <source srcset={withBase('/brand/logo.webp')} type="image/webp" />
        <img
          src={withBase('/brand/logo.png')}
          alt=""
          width="40" height="40"
          class="h-9 w-9 sm:h-11 sm:w-11 object-contain"
          decoding="async"
          fetchpriority="high"
        />
      </picture>
      <span class="display text-brand-cream text-lg leading-none whitespace-nowrap hidden sm:inline">
        Pimp My <span class="text-brand-gold">Kebap</span>
      </span>
    </a>

    <!-- Compact status: dot + 1-2 words on mobile, full label ≥sm -->
    <span
      class={`flex items-center gap-1.5 text-xs whitespace-nowrap ${toneClass}`}
      data-opening-pill
      role="status"
      aria-label={fullLabel}
    >
      <span class={`w-2 h-2 rounded-full ${dotColor} animate-pulse`} aria-hidden="true"></span>
      <span class="sm:hidden font-semibold">{shortLabel}</span>
      <span class="hidden sm:inline">{fullLabel}</span>
    </span>

    <!-- Spacer pushes actions to the right -->
    <span class="flex-1"></span>

    <!-- Phone icon-only on mobile, full button ≥sm -->
    <a
      href={`tel:${BRAND.contact.phoneE164}`}
      class="text-brand-cream/85 hover:text-brand-gold transition-colors p-2 -mr-1 sm:hidden"
      aria-label={`Anrufen ${BRAND.contact.phoneDisplay}`}
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
    </a>
    <a
      href={`tel:${BRAND.contact.phoneE164}`}
      class="btn-secondary text-xs !py-2 hidden sm:inline-flex"
      aria-label={`Anrufen ${BRAND.contact.phoneDisplay}`}
    >
      ☎ Anrufen
    </a>
    <a
      href={withBase('/') + '#konfigurator'}
      class="btn-primary text-xs !py-2 hidden sm:inline-flex"
    >Bestellen</a>
  </div>
</header>
