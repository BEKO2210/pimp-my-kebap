---
// Powered by skill: frontend-design, accessibility, brand-guidelines, artifacts-builder
// Anti-AI-slop notes: NO centered-only layout, asymmetric grid on desktop,
// gold ↔ fire-orange accents (no purple), varied radii.
import { BRAND } from '../data/brand';
import { withBase } from '../lib/url';
import { offerForDay } from '../data/weeklyOffers';
import { getCurrentWeekday } from '../lib/time';

const offer = offerForDay(getCurrentWeekday());
---

<section
  id="hero"
  class="relative overflow-hidden px-4 sm:px-6 lg:px-8 pt-10 pb-16 sm:pt-16 sm:pb-24"
  aria-labelledby="hero-heading"
>
  <div aria-hidden="true" class="absolute inset-0 -z-10 pointer-events-none">
    <div class="absolute -top-40 right-[-12rem] w-[44rem] h-[44rem] rounded-full bg-brand-orange/15 blur-[120px] hero-blob"></div>
    <div class="absolute top-1/3 left-[-12rem] w-[34rem] h-[34rem] rounded-full bg-brand-gold/15 blur-[120px] hero-blob hero-blob-2"></div>
    <div class="hero-grid absolute inset-0 opacity-[0.04]"></div>
  </div>

  <div class="mx-auto max-w-6xl grid gap-10 lg:grid-cols-12 lg:items-center">
    <!-- Text column: 7/12, deliberately not centered -->
    <div class="lg:col-span-7 text-left">
      <p class="eyebrow">
        <span>{BRAND.slogans.tagline}</span>
      </p>
      <h1
        id="hero-heading"
        class="display text-4xl sm:text-6xl lg:text-7xl text-brand-cream leading-[1.02] mt-4 tracking-[-0.02em]"
      >
        <span class="text-brand-gold italic">Create</span> Your<br />
        Kebap. <span class="text-brand-orange">Pay</span> Your<br />
        Style<span class="text-brand-gold">.</span>
      </h1>
      <p class="mt-5 text-brand-cream/80 max-w-xl text-lg leading-relaxed">
        4 Brote, 6 Soßen, 18 frische Zutaten. Stell ihn dir genau so zusammen,
        wie du ihn liebst — und sende deine Bestellung in 30 Sekunden per WhatsApp.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href={withBase('/') + '#konfigurator'} class="btn-primary">Jetzt konfigurieren →</a>
        <a href={withBase('/') + '#speisekarte'} class="btn-secondary">Speisekarte ansehen</a>
        <button
          type="button"
          data-surprise-me
          class="btn-secondary text-sm"
          aria-label="Zufalls-Kebap konfigurieren lassen"
        >🎲 Surprise Me</button>
      </div>
      <dl class="mt-10 grid grid-cols-3 gap-4 max-w-md">
        <div>
          <dt class="text-xs uppercase tracking-widest text-brand-cream/55">Brote</dt>
          <dd class="display text-3xl text-brand-cream num">4</dd>
        </div>
        <div>
          <dt class="text-xs uppercase tracking-widest text-brand-cream/55">Soßen</dt>
          <dd class="display text-3xl text-brand-cream num">6</dd>
        </div>
        <div>
          <dt class="text-xs uppercase tracking-widest text-brand-cream/55">Zutaten</dt>
          <dd class="display text-3xl text-brand-cream num">18</dd>
        </div>
      </dl>
    </div>

    <!-- Logo + offer card column: 5/12, offset down to break symmetry -->
    <div class="lg:col-span-5 lg:translate-y-6">
      <div class="relative">
        <div class="absolute inset-0 -z-10 bg-gradient-to-br from-brand-gold/15 via-transparent to-brand-orange/15 blur-2xl rounded-full"></div>
        <picture>
          <source srcset={withBase('/brand/logo.avif')} type="image/avif" />
          <source srcset={withBase('/brand/logo.webp')} type="image/webp" />
          <img
            src={withBase('/brand/logo.png')}
            alt="Pimp My Kebap Logo"
            width="380" height="380"
            class="mx-auto block w-48 sm:w-64 lg:w-full max-w-sm h-auto drop-shadow-[0_20px_60px_rgba(212,175,55,0.25)]"
            fetchpriority="high"
            decoding="async"
          />
        </picture>
      </div>
      {offer && (
        <a
          href={withBase('/') + '#aktion'}
          class="mt-6 block card !rounded-tl-3xl !rounded-br-none p-4 hover:translate-x-1 transition-transform"
          aria-label={`Heute: ${offer.title}`}
        >
          <p class="eyebrow">Heute · {offer.shortLabel}</p>
          <p class="display text-2xl text-brand-cream mt-1">{offer.title}</p>
          <p class="text-brand-cream/65 text-sm mt-1">{offer.description}</p>
          <p class="text-brand-gold mt-2 num font-semibold">{offer.badge}</p>
        </a>
      )}
    </div>
  </div>

  <p class="section-divider mt-12" aria-hidden="true"></p>
</section>

<style>
  .hero-blob {
    animation: float 22s ease-in-out infinite alternate;
  }
  .hero-blob-2 { animation-duration: 28s; animation-delay: -8s; }
  .hero-grid {
    background-image:
      linear-gradient(to right, var(--color-brand-gold) 1px, transparent 1px),
      linear-gradient(to bottom, var(--color-brand-gold) 1px, transparent 1px);
    background-size: 96px 96px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 30%, black 35%, transparent 75%);
  }
  @keyframes float {
    from { transform: translate3d(0, 0, 0) scale(1); }
    to { transform: translate3d(60px, 40px, 0) scale(1.12); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-blob { animation: none !important; }
  }
</style>
