---
// Powered by skill: frontend-design, accessibility
import { BRAND } from '../data/brand';
import { withBase } from '../lib/url';
---

<section
  id="hero"
  class="relative overflow-hidden px-4 sm:px-6 lg:px-8 pt-12 pb-20 sm:pt-20 sm:pb-28"
  aria-labelledby="hero-heading"
>
  <!-- Animated glow blobs (CSS only, reduced-motion aware) -->
  <div aria-hidden="true" class="absolute inset-0 -z-10 pointer-events-none">
    <div class="absolute -top-32 -right-24 w-[34rem] h-[34rem] rounded-full bg-brand-orange/20 blur-3xl hero-blob"></div>
    <div class="absolute top-1/2 -left-32 w-[26rem] h-[26rem] rounded-full bg-brand-gold/20 blur-3xl hero-blob hero-blob-2"></div>
  </div>
  <div class="mx-auto max-w-4xl text-center">
    <picture>
      <source srcset={withBase('/brand/logo.avif')} type="image/avif" />
      <source srcset={withBase('/brand/logo.webp')} type="image/webp" />
      <img
        src={withBase('/brand/logo.png')}
        alt="Pimp My Kebap Logo"
        width="200" height="200"
        class="mx-auto h-32 sm:h-40 w-auto"
        fetchpriority="high"
        decoding="async"
      />
    </picture>
    <p class="mt-4 text-brand-gold uppercase tracking-[0.3em] text-xs">
      {BRAND.slogans.tagline}
    </p>
    <h1 id="hero-heading" class="display text-4xl sm:text-6xl text-brand-cream leading-[1.05] mt-3">
      <span class="text-brand-gold">Create</span> Your Kebap.<br />
      Pay Your Style.
    </h1>
    <p class="mt-4 text-brand-cream/80 max-w-xl mx-auto">
      4 Brote, 6 Soßen, 18 frische Zutaten. Stell ihn dir genau so zusammen, wie du ihn liebst —
      und sende deine Bestellung in 30 Sekunden per WhatsApp.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a href={withBase('/') + '#konfigurator'} class="btn-primary">Jetzt konfigurieren →</a>
      <a href={withBase('/') + '#speisekarte'} class="btn-secondary">Speisekarte ansehen</a>
    </div>
  </div>
</section>

<style>
  .hero-blob {
    animation: float 18s ease-in-out infinite alternate;
  }
  .hero-blob-2 { animation-duration: 22s; animation-delay: -6s; }
  @keyframes float {
    from { transform: translate3d(0, 0, 0) scale(1); }
    to { transform: translate3d(40px, 30px, 0) scale(1.1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-blob { animation: none !important; }
  }
</style>
