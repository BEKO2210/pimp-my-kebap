---
// Powered by skill: frontend-design
import { TOPPINGS } from '../data/ingredients';
import Icon from './Icon.astro';
---

<section id="zutaten" class="px-4 sm:px-6 lg:px-8 py-12" aria-labelledby="zutaten-heading">
  <div class="mx-auto max-w-6xl">
    <p class="text-brand-gold uppercase tracking-widest text-xs font-bold mb-2">Salatbar</p>
    <h2 id="zutaten-heading" class="display text-2xl sm:text-3xl text-brand-cream mb-2">19 frische Zutaten</h2>
    <p class="text-brand-cream/65 max-w-2xl mb-6">
      Granatapfel, Feldsalat, Rucola, Ofengemüse — wir machen den Salat, der zu deinem Geschmack passt.
    </p>
    <ul class="grid grid-cols-3 sm:grid-cols-6 gap-3">
      {TOPPINGS.map((t) => (
        <li class="card p-3 flex flex-col items-center justify-center gap-1 text-center min-h-[5rem]">
          <span class="text-brand-cream text-sm">{t.name}</span>
          {t.spicy && <Icon name="flame" size={14} class="text-brand-red-fire" ariaLabel="scharf" />}
        </li>
      ))}
    </ul>
  </div>
</section>
