---
// Powered by skill: frontend-design, accessibility, image-optimization
import type { MenuItem } from '../../data/menu';
import AllergenBadge from '../AllergenBadge.astro';
import { CATEGORY_TO_PLACEHOLDER, CATEGORY_LABEL, cartItemName } from '../../data/menu';
import { formatEUR } from '../../lib/format';
import { withBase } from '../../lib/url';
import Icon from '../Icon.astro';

interface Props {
  item: MenuItem;
}

const { item } = Astro.props;
// WICHTIG: Karten werden weekday-NEUTRAL gerendert (kanonischer Vollpreis,
// kein Tages-Aktion-Promo, Schüler immer als "bestellbar"). Die Site ist
// statisch (GitHub Pages) — ein build-time Promo/Schulzeit-Wert waere fuer
// alle Besucher bis zum naechsten Build eingefroren. menuHydrate.client.ts
// rechnet Promo-Preise + Schüler-Verfügbarkeit nach DOM-Ready clientseitig.
const fullPrice = item.priceEur; // number | null ("Auf Anfrage")
const isOnRequest = fullPrice === null;
const slug = CATEGORY_TO_PLACEHOLDER[item.category] ?? 'doener';
const photoBase = withBase(`/images/meals/${item.id}`);
const placeholder = withBase(`/images/placeholders/${slug}.svg`);
const isSchoolItem = item.schoolHoursOnly === true;
// Kanonisch bestellbar = solange ein Preis existiert. Die Schüler-Zeitfenster-
// Sperre (Mo–Fr ≤16:00) wird erst clientseitig gesetzt.
const canOrder = !isOnRequest;
// When the item carries options (Beilage / Drehspieß / …) the +-button no
// longer adds directly — it opens the options dialog. The options payload is
// JSON-serialised onto the card so the client doesn't need a separate fetch.
const hasOptions = (item.options?.length ?? 0) > 0;
const promoMap = item.promoPriceMap ?? {};
const optionsPayload = hasOptions
  ? JSON.stringify({
      itemId: item.id,
      itemName: cartItemName(item),
      category: item.category,
      description: item.description,
      basePriceEur: fullPrice,
      promo: false,
      options: item.options,
      imgBase: `/images/meals/${item.id}`,
      fallback: `/images/placeholders/${slug}.svg`,
    })
  : null;
---

<article
  class="card overflow-hidden flex flex-col"
  data-item-id={item.id}
  data-item-name={cartItemName(item)}
  data-item-category={item.category}
  data-item-price={fullPrice ?? ''}
  data-item-base-price={fullPrice ?? ''}
  data-item-promo="false"
  data-item-promo-map={JSON.stringify(promoMap)}
  data-item-school={isSchoolItem ? 'true' : 'false'}
  data-item-tag={item.tag ?? ''}
  data-item-markings={(item.markings ?? []).join(',')}
  data-item-search={`${cartItemName(item)} ${CATEGORY_LABEL[item.category]} ${item.description ?? ''} ${item.tag ?? ''}`.toLowerCase()}
  data-item-orderable={canOrder ? 'true' : 'false'}
  data-item-has-options={hasOptions ? 'true' : 'false'}
  data-item-options={optionsPayload}
  itemscope
  itemtype="https://schema.org/MenuItem"
>
  <div class="relative aspect-[4/3] bg-brand-charcoal-soft overflow-hidden">
    <picture class="absolute inset-0 block w-full h-full">
      <source srcset={`${photoBase}.avif`} type="image/avif" />
      <source srcset={`${photoBase}.webp`} type="image/webp" />
      <img
        src={`${photoBase}.jpg`}
        alt={item.name}
        loading="lazy"
        decoding="async"
        width="640" height="480"
        class="absolute inset-0 w-full h-full object-cover"
        data-fallback={placeholder}
      />
    </picture>
    {item.tag === 'neu' && (
      <span class="absolute top-2 left-2 badge badge-new">NEU</span>
    )}
    {item.tag === 'scharf' && (
      <span class="absolute top-2 left-2 badge badge-spicy inline-flex items-center gap-1">
        <Icon name="flame" size={12} />
        <span>Scharf</span>
      </span>
    )}
    {item.tag === 'vegetarisch' && (
      <span class="absolute top-2 left-2 badge badge-veg">Vegetarisch</span>
    )}
    {/* Promo-Badge wird clientseitig eingeblendet (Tages-Aktion). */}
    <span class="absolute top-2 right-2 badge badge-gold" data-promo-badge hidden>Aktion</span>
  </div>
  <div class="p-4 flex flex-col gap-2 flex-1">
    <div class="flex items-baseline justify-between gap-2">
      <h3 class="display text-lg text-brand-cream line-clamp-2" itemprop="name">{item.name}</h3>
      <AllergenBadge markings={item.markings} itemName={item.name} />
    </div>
    {item.description && (
      <p class="text-xs text-brand-cream/65 line-clamp-2" itemprop="description">{item.description}</p>
    )}
    <div class="mt-auto flex items-end justify-between gap-2">
      <div class="min-w-0 flex flex-col gap-0.5" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
        <span itemprop="priceCurrency" hidden>EUR</span>
        <p class="text-brand-gold display text-xl num leading-tight">
          {isOnRequest ? (
            <span class="text-sm text-brand-cream/60">Auf Anfrage</span>
          ) : (
            <>
              {/* Originalpreis (Strikethrough) — clientseitig bei Aktion eingeblendet. */}
              <del class="text-brand-cream/55 text-sm num mr-1.5 font-normal align-middle" data-price-original hidden></del>
              <span itemprop="price" data-price-current data-content={String(fullPrice ?? 0)}>{formatEUR(fullPrice ?? 0)}</span>
            </>
          )}
        </p>
        {!isOnRequest && (
          <p class="text-[11px] text-brand-gold/90 num leading-tight font-semibold" data-price-savings hidden></p>
        )}
      </div>
      {canOrder && (
        <div class="inline-flex items-center gap-1 shrink-0" role="group" aria-label={`Menge ${item.name}`} data-order-stepper>
          <button
            type="button"
            data-item-dec
            class="btn-secondary !px-3 !py-2 text-base disabled:opacity-30"
            aria-label={`${item.name} weniger`}
          >−</button>
          <span data-item-qty class="num min-w-[2ch] text-center font-semibold text-brand-cream">0</span>
          <button
            type="button"
            data-item-inc
            class="btn-primary text-sm !px-3 !py-2 min-w-[6rem]"
            aria-label={hasOptions ? `${item.name} auswählen und hinzufügen` : `${item.name} mehr / hinzufügen`}
          >{hasOptions ? 'Auswählen' : '+'}</button>
        </div>
      )}
      {/* Schüler-Hinweis (außerhalb Schulzeit) — clientseitig ein-/ausgeblendet. */}
      {isSchoolItem && canOrder && (
        <span class="text-xs text-brand-cream/55 shrink-0" data-order-reason hidden>Nur Mo–Fr bis 16:00 Uhr</span>
      )}
    </div>
  </div>
</article>
