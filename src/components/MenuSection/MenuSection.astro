---
// Powered by skill: frontend-design
import type { MenuCategory } from '../../data/menu';
import { itemsByCategory, CATEGORY_LABEL } from '../../data/menu';
import ItemCard from '../ItemCard/ItemCard.astro';
import Icon from '../Icon.astro';
import { withBase } from '../../lib/url';

interface Props {
  category: MenuCategory;
  /** When set, descriptive blurb under heading. */
  blurb?: string;
  /** Pre-computed item count for the summary line. */
  itemCount?: number;
  /** Optional CTA card rendered before the items grid (e.g. "Konfigurator"). */
  ctaHref?: string;
  ctaLabel?: string;
  ctaDescription?: string;
  ctaIcon?: 'kebap' | 'pizza';
}

const {
  category,
  blurb,
  itemCount,
  ctaHref,
  ctaLabel,
  ctaDescription,
  ctaIcon,
} = Astro.props;
const items = itemsByCategory(category);
const isSchoolSection = category === 'schueler';
const count = itemCount ?? items.length;
// Hinweis: Promo-Preise (Tages-Aktion) und die Schüler-Verfügbarkeit
// (Mo–Fr ≤16:00) werden NICHT zur Build-Zeit gesetzt — die Site ist statisch.
// menuHydrate.client.ts uebernimmt das clientseitig. Hier wird kanonisch der
// "Schulzeit offen"-Zustand gerendert; der Client schaltet ggf. auf "zu" um.
---

<section
  id={`section-${category}`}
  class="px-4 sm:px-6 lg:px-8"
  data-menu-section={category}
  data-school-section={isSchoolSection ? 'true' : undefined}
  aria-labelledby={`heading-${category}`}
>
  <div class="mx-auto max-w-6xl">
    <details class="menu-accordion border-t border-brand-gold/15 py-4" data-menu-accordion>
      <summary
        class="list-none flex items-center justify-between gap-4 cursor-pointer py-2 select-none"
        id={`heading-${category}`}
      >
        <div class="flex items-center gap-3 min-w-0">
          <h2 class="display text-2xl sm:text-3xl text-brand-cream truncate">
            {CATEGORY_LABEL[category]}
          </h2>
          <span class="text-xs text-brand-cream/50 num shrink-0">
            ({count} {count === 1 ? 'Speise' : 'Speisen'})
          </span>
          {isSchoolSection && (
            <span class="badge badge-veg hidden sm:inline-flex shrink-0" data-school-badge>
              Mo–Fr ≤16:00
            </span>
          )}
        </div>
        <span class="menu-accordion-chevron text-brand-gold shrink-0" aria-hidden="true">
          <Icon name="chevron-down" size={20} />
        </span>
      </summary>
      {blurb && <p class="text-sm text-brand-cream/65 mt-2 max-w-2xl">{blurb}</p>}

      {ctaHref && ctaLabel && (
        <a
          href={withBase(ctaHref)}
          class="block mt-4 rounded-xl border border-brand-gold/40 bg-gradient-to-br from-brand-gold/10 via-transparent to-brand-orange/10 p-4 sm:p-5 hover:border-brand-gold transition-colors group"
          data-cfg-cta
        >
          <div class="flex items-start gap-3 sm:gap-4">
            {ctaIcon && (
              <span class="text-brand-gold shrink-0 mt-0.5">
                <Icon name={ctaIcon} size={28} />
              </span>
            )}
            <div class="min-w-0 flex-1">
              <p class="display text-lg text-brand-cream group-hover:text-brand-gold transition-colors">
                {ctaLabel}
              </p>
              {ctaDescription && (
                <p class="text-sm text-brand-cream/70 mt-1">{ctaDescription}</p>
              )}
            </div>
            <span class="text-brand-gold shrink-0 self-center group-hover:translate-x-1 transition-transform">
              <Icon name="arrow-right" size={20} />
            </span>
          </div>
        </a>
      )}

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-5">
        {items.map((item) => <ItemCard item={item} />)}
      </div>
    </details>
  </div>
</section>

<style>
  /* Hide the default <summary> marker (Safari/Firefox/Chrome). */
  details[data-menu-accordion] > summary::-webkit-details-marker { display: none; }
  details[data-menu-accordion] > summary::marker { content: ''; }
  /* Rotate the chevron when open. */
  details[data-menu-accordion][open] > summary .menu-accordion-chevron {
    transform: rotate(180deg);
  }
  details[data-menu-accordion] > summary .menu-accordion-chevron {
    transition: transform 180ms ease;
    display: inline-flex;
  }
</style>
