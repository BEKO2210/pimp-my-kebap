---
// Powered by skill: seo-local, security
// Static OSM tile via <img> — DSGVO-friendly preview (no JS map, no iframe,
// no Google tracking). The "Route in Google Maps" CTA below opens directions
// in Google Maps, which is what most customers actually navigate with.
import { BRAND } from '../data/brand';
import Icon from './Icon.astro';

const { latitude, longitude } = BRAND.geo;
// OSM static-tile URL: zoom 17, 600x400. Allowed under CSP img-src.
const tileX = Math.floor(((longitude + 180) / 360) * 2 ** 17);
const lat_rad = (latitude * Math.PI) / 180;
const tileY = Math.floor(
  ((1 - Math.log(Math.tan(lat_rad) + 1 / Math.cos(lat_rad)) / Math.PI) / 2) * 2 ** 17,
);
const mapImg = `https://tile.openstreetmap.org/17/${tileX}/${tileY}.png`;
// Google Maps directions deep-link — works on iOS, Android and desktop.
const destination = encodeURIComponent(
  `${BRAND.address.street}, ${BRAND.address.postalCode} ${BRAND.address.city}`,
);
const directionsUrl = `https://www.google.com/maps/dir/?api=1&destination=${destination}`;
---

<section id="standort" class="px-4 sm:px-6 lg:px-8 py-12" aria-labelledby="standort-heading">
  <div class="mx-auto max-w-6xl grid lg:grid-cols-2 gap-8 items-start">
    <div>
      <p class="text-brand-gold uppercase tracking-widest text-xs font-bold mb-2">Standort & Anfahrt</p>
      <h2 id="standort-heading" class="display text-2xl sm:text-3xl text-brand-cream">
        Mitten im Marktplatz von Freiberg
      </h2>
      <address class="not-italic text-brand-cream/85 mt-4 space-y-1">
        <p><strong>{BRAND.marketingName}</strong></p>
        <p class="flex items-center gap-2">
          <Icon name="map-pin" size={16} class="text-brand-gold shrink-0" />
          <span>{BRAND.address.street}, {BRAND.address.postalCode} {BRAND.address.city}</span>
        </p>
        <p class="flex items-center gap-2 pt-2">
          <Icon name="phone" size={16} class="text-brand-gold shrink-0" />
          <a href={`tel:${BRAND.contact.phoneE164}`} class="underline decoration-brand-gold/40 hover:decoration-brand-gold">{BRAND.contact.phoneDisplay}</a>
        </p>
        <p class="flex items-center gap-2">
          <Icon name="mail" size={16} class="text-brand-gold shrink-0" />
          <a href={`mailto:${BRAND.contact.email}`} class="underline decoration-brand-gold/40 hover:decoration-brand-gold">{BRAND.contact.email}</a>
        </p>
      </address>
      <h3 class="display text-lg text-brand-cream mt-6">Öffnungszeiten</h3>
      <dl class="text-sm text-brand-cream/85 mt-2 space-y-1">
        <div class="flex justify-between max-w-xs"><dt>Mo – Sa</dt><dd>{BRAND.openingHours.weekday.open} – {BRAND.openingHours.weekday.close} Uhr</dd></div>
        <div class="flex justify-between max-w-xs"><dt>So</dt><dd>geschlossen</dd></div>
        <div class="flex justify-between max-w-xs"><dt>Feiertags</dt><dd>{BRAND.openingHours.holiday.open} – {BRAND.openingHours.holiday.close} Uhr</dd></div>
      </dl>
      {BRAND.social.instagramUrl && (
        <p class="mt-4 flex items-center gap-2 text-sm text-brand-cream/70">
          <Icon name="instagram" size={16} class="text-brand-gold shrink-0" />
          <a href={BRAND.social.instagramUrl} target="_blank" rel="noopener noreferrer" class="underline decoration-brand-gold/40 hover:decoration-brand-gold">@{BRAND.social.instagramHandle}</a>
        </p>
      )}
    </div>
    <div class="card overflow-hidden">
      <a
        href={directionsUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Route zu ${BRAND.marketingName} in Google Maps`}
        class="block group"
      >
        <img src={mapImg} alt={`Karte ${BRAND.address.street}`} width="600" height="400" loading="lazy" decoding="async" class="w-full h-auto block" />
        <div class="flex items-start gap-3 px-4 py-3 group-hover:bg-brand-charcoal-soft/40 transition-colors">
          <Icon name="map-pin" size={18} class="text-brand-gold shrink-0 mt-0.5" />
          <div class="text-sm flex-1 min-w-0">
            <p class="text-brand-cream font-semibold">{BRAND.marketingName}</p>
            <p class="text-brand-cream/80">{BRAND.address.street}</p>
            <p class="text-brand-cream/80">{BRAND.address.postalCode} {BRAND.address.city}</p>
            <p class="text-brand-gold mt-1 group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
              <span>Route in Google Maps öffnen →</span>
            </p>
          </div>
        </div>
      </a>
    </div>
  </div>
</section>
