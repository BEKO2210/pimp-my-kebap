---
// Powered by skill: frontend-design
---
<section id="warum" class="px-4 sm:px-6 lg:px-8 py-12" aria-labelledby="warum-heading">
  <div class="mx-auto max-w-5xl text-center">
    <p class="text-brand-gold uppercase tracking-widest text-xs font-bold mb-2">Unsere Philosophie</p>
    <h2 id="warum-heading" class="display text-2xl sm:text-3xl text-brand-cream">
      Mehr Genuss. Mehr Ideen. Mehr Extra.
    </h2>
    <div class="mt-8 grid sm:grid-cols-3 gap-4 text-left">
      <div class="card p-5">
        <p class="display text-brand-gold text-2xl">100 g</p>
        <p class="text-brand-cream font-semibold mt-2">Fleisch im Standard</p>
        <p class="text-brand-cream/70 text-sm mt-1">Klare Mengenangabe statt Pi-mal-Daumen.</p>
      </div>
      <div class="card p-5">
        <p class="display text-brand-gold text-2xl">6 €</p>
        <p class="text-brand-cream font-semibold mt-2">Schüler-Döner</p>
        <p class="text-brand-cream/70 text-sm mt-1">Mo–Fr bis 16:00 Uhr — fair und sättigend.</p>
      </div>
      <div class="card p-5">
        <p class="display text-brand-gold text-2xl">+0,50 €</p>
        <p class="text-brand-cream font-semibold mt-2">Pro Topping. Punkt.</p>
        <p class="text-brand-cream/70 text-sm mt-1">Transparente Preise — keine versteckten Kosten.</p>
      </div>
    </div>
  </div>
</section>
