---
// Powered by skill: frontend-design, seo-local
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import WeeklyBanner from '../components/WeeklyBanner.astro';
import Hero from '../components/Hero.astro';
import HomeNav from '../components/HomeNav.astro';
import IngredientsGallery from '../components/IngredientsGallery.astro';
import Warum from '../components/Warum.astro';
import DeliveryArea from '../components/DeliveryArea.astro';
import OrderHistory from '../components/OrderHistory.astro';
import Standort from '../components/Standort.astro';
import Footer from '../components/Footer.astro';
import CartDrawer from '../components/Cart/CartDrawer.astro';
import Icon from '../components/Icon.astro';
import {
  buildRestaurantJsonLd,
  buildMenuJsonLd,
  buildBreadcrumbJsonLd,
} from '../lib/jsonld';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL ?? 'https://beko2210.github.io/pimp-my-kebap').replace(/\/$/, '');
const jsonLd = [
  buildRestaurantJsonLd(siteUrl),
  buildMenuJsonLd(siteUrl),
  buildBreadcrumbJsonLd(siteUrl),
];

const wa = import.meta.env.PUBLIC_RESTAURANT_WHATSAPP;
const waMissing = !wa || wa.length === 0;
---

<Base
  title="Pimp My Kebap Freiberg — Döner & Pizza per WhatsApp"
  description="Pimp my Kebap und Pimp my Pizza: 19 frische Zutaten, 4 Brote, 6 Soßen. Stell dir Kebap oder Pizza zusammen, blättere durch die Speisekarte, bestelle per WhatsApp."
  pathname="/"
  jsonLd={jsonLd}
>
  <Header slot="header" />
  <Footer slot="footer" />

  <WeeklyBanner />
  {waMissing && (
    <p class="bg-brand-red-fire/15 border-y border-brand-red-fire/40 text-brand-cream text-sm px-4 py-2 text-center inline-flex items-center justify-center gap-2 w-full">
      <Icon name="alert" size={16} class="text-brand-red-fire" />
      <span>Bestellung deaktiviert: WhatsApp-Nummer fehlt in der Konfiguration.</span>
    </p>
  )}
  <Hero />
  <HomeNav />
  <IngredientsGallery />
  <Warum />
  <DeliveryArea />
  <OrderHistory />
  <Standort />
  <CartDrawer />
</Base>
