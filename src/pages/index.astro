---
// Powered by skill: frontend-design, seo-local
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import WeeklyBanner from '../components/WeeklyBanner.astro';
import Hero from '../components/Hero.astro';
import Configurator from '../components/Configurator/Configurator.astro';
import Speisekarte from '../components/Speisekarte.astro';
import IngredientsGallery from '../components/IngredientsGallery.astro';
import Warum from '../components/Warum.astro';
import DeliveryArea from '../components/DeliveryArea.astro';
import Standort from '../components/Standort.astro';
import Footer from '../components/Footer.astro';
import CartDrawer from '../components/Cart/CartDrawer.astro';
import {
  buildRestaurantJsonLd,
  buildMenuJsonLd,
  buildBreadcrumbJsonLd,
} from '../lib/jsonld';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL ?? 'https://pimp-my-kebap.de').replace(/\/$/, '');

const jsonLd = [
  buildRestaurantJsonLd(siteUrl),
  buildMenuJsonLd(siteUrl),
  buildBreadcrumbJsonLd(siteUrl),
];

const wa = import.meta.env.PUBLIC_RESTAURANT_WHATSAPP;
const waMissing = !wa || wa.length === 0;
---

<Base
  title="Pimp My Kebap Freiberg am Neckar — Döner konfigurieren & per WhatsApp bestellen"
  description="18 frische Zutaten, 4 Brote, 6 Soßen — konfiguriere deinen Kebap und sende die Bestellung in 30 Sekunden per WhatsApp an Pimp My Kebap, Marktplatz 18, Freiberg am Neckar."
  pathname="/"
  jsonLd={jsonLd}
>
  <Header slot="header" />
  <Footer slot="footer" />

  <WeeklyBanner />
  {waMissing && (
    <p class="bg-brand-red-fire/15 border-y border-brand-red-fire/40 text-brand-cream text-sm px-4 py-2 text-center">
      ⚠️ Bestellung deaktiviert: WhatsApp-Nummer fehlt in der Konfiguration. (Setze <code>PUBLIC_RESTAURANT_WHATSAPP</code>.)
    </p>
  )}
  <Hero />
  <Configurator />
  <Speisekarte />
  <IngredientsGallery />
  <Warum />
  <DeliveryArea />
  <Standort />
  <CartDrawer />
</Base>
