---
// Powered by skill: frontend-design, seo-local
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WeeklyBanner from '../../components/WeeklyBanner.astro';
import Configurator from '../../components/Configurator/Configurator.astro';
import CartDrawer from '../../components/Cart/CartDrawer.astro';
import { withBase } from '../../lib/url';
---

<Base
  title="Pimp my Kebap — Konfigurator · Freiberg"
  description="Konfiguriere deinen Kebap: Brot, Basis, Spieß (Chicken Kebab / Hackfleisch Drehspieß / Steak Döner), Soßen und Toppings. Live-Preis, Bestellung per WhatsApp."
  pathname="/konfigurator"
>
  <Header slot="header" />
  <Footer slot="footer" />

  <WeeklyBanner />

  <nav aria-label="Brotkrumen" class="px-4 sm:px-6 lg:px-8 pt-4">
    <p class="text-xs text-brand-cream/55">
      <a href={withBase('/')} class="hover:text-brand-cream">Start</a> ·
      <span class="text-brand-cream/85">Konfigurator</span>
    </p>
  </nav>

  <Configurator />
  <CartDrawer />
</Base>
