---
// Powered by skill: frontend-design, seo-local
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WeeklyBanner from '../../components/WeeklyBanner.astro';
import PizzaConfigurator from '../../components/PizzaConfigurator/PizzaConfigurator.astro';
import CartDrawer from '../../components/Cart/CartDrawer.astro';
import { withBase } from '../../lib/url';
---

<Base
  title="Pimp my Pizza — Konfigurator · Freiberg"
  description="Pizzaboden mit Tomatensoße & Käse als Basis. 22 Toppings zur freien Auswahl. Live-Preis, Bestellung per WhatsApp."
  pathname="/pimp-my-pizza"
>
  <Header slot="header" />
  <Footer slot="footer" />

  <WeeklyBanner />

  <nav aria-label="Brotkrumen" class="px-4 sm:px-6 lg:px-8 pt-4">
    <p class="text-xs text-brand-cream/55">
      <a href={withBase('/')} class="hover:text-brand-cream">Start</a> ·
      <span class="text-brand-cream/85">Pimp my Pizza</span>
    </p>
  </nav>

  <PizzaConfigurator />
  <CartDrawer />
</Base>
